# OpenRouter API Key (Get yours from https://openrouter.ai/keys)
OPENROUTER_API_KEY=your-openrouter-api-key

# A secure random key to authorize connection between Open WebUI and Hermes Agent
INTERNAL_API_KEY=super-secret-internal-key-change-me

# The model configured for the Hermes Agent (OpenRouter model ID)
API_SERVER_MODEL_NAME=deepseek/deepseek-v4-flash


# GitHub Access (e.g., Personal Access Tokens, Copilot access)
GITHUB_TOKEN=your-github-token
GH_TOKEN=your-github-token

